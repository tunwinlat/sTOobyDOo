# ============================================
# sTOobyDOo - Environment Variables
# ============================================

# -------------------------------------------------
# LOCAL DEVELOPMENT (SQLite)
# -------------------------------------------------
# For local development, use SQLite:
# DATABASE_URL="file:./dev.db"
# NEXTAUTH_SECRET="dev-secret-not-for-production"

# -------------------------------------------------
# PRODUCTION (Turso/libsql) - Set in Vercel Dashboard
# -------------------------------------------------
# These are REQUIRED for Vercel deployment:
#
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"
# NEXTAUTH_SECRET="your-generated-secret-min-32-chars"
#
# Note: Database will be auto-initialized on first deploy!
# No manual migration needed.

# -------------------------------------------------
# Getting Your Turso Credentials:
# -------------------------------------------------
# 1. Install Turso CLI: npm install -g @tursodatabase/turso
# 2. Login: turso auth login
# 3. Create DB: turso db create family-todo
# 4. Get URL: turso db show family-todo
# 5. Get Token: turso db tokens create family-todo

# -------------------------------------------------
# OPTIONAL: Notification Settings
# -------------------------------------------------
# These can also be set via the UI after deployment
# PUSHOVER_APP_TOKEN=""
# PUSHOVER_USER_KEY=""
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL=""

# -------------------------------------------------
# OPTIONAL: NextAuth URL
# -------------------------------------------------
# Auto-detected on Vercel, but you can set explicitly:
# NEXTAUTH_URL="https://your-app.vercel.app"
